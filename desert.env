###MODEL_COLLISION###
func GetModelHitboxType()
if [&PLAYER+TYPE& = PL_EMPLOY] then
{
  [Return] MODEL_CREATED $WITH$ _drawTriWithCoords_&Center-0_@@widthMax(-50, +50)@@heightMax(CURGROUNDY$$0, +50)@@widthMax(NaN, 0) @@VAR_HITBOX*TYPE
}
else 
if [&PLAYER+TYPE& = CHOLL_PLAY] then
{
  [Return] MODEL_CREATED = TYPE*HITBOX_CURRENT @@VAR_HITBOX*TYPE
}
endFunc


